# ─────────────────────────────────────────────────────────────
# AI Teaching Assistant — 환경 변수
# 이 파일을 복사해서 `.env` 로 저장한 뒤 값을 채우세요.
#   cp .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)
# ─────────────────────────────────────────────────────────────

# DB (SQLite, 로컬 파일). 프로젝트 루트에 dev.db 가 생성됩니다.
DATABASE_URL="file:./dev.db"

# AI Provider: openai | claude | gemini | grok | ollama
AI_PROVIDER="claude"
AI_API_KEY=""
AI_BASE_URL=""
AI_MODEL=""

# NextAuth (교수 로그인 세션 서명용 시크릿) — 필수.
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# 초기 관리자(교수) 계정 — `npm run db:seed` / `npm run setup` 이 이 값으로 계정을 만듭니다.
# 첫 로그인에 사용하며, 운영 전 비밀번호를 반드시 변경하세요.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme1234"
ADMIN_NAME="관리자"

# (선택) 업로드 파일 저장 경로. 미설정 시 <프로젝트 루트>/uploads 사용.
# UPLOADS_DIR=""
